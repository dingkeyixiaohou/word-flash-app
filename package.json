{
  "name": "word-flash-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:cf": "vite build && npx esbuild _worker.ts --bundle --platform=browser --target=es2022 --format=esm --outfile=dist/_worker.js",
    "preview": "vite preview",
    "server": "tsx server/index.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10",
    "wrangler": "^4.90.0"
  }
}
